# LeakSanitizer suppressions for the XS binary.
#
# Only suppress allocations whose lifetime is deliberately process-wide.
# Anything per-request or per-program run must be freed and NOT suppressed;
# those leaks indicate a real bug.
#
# If a future change makes one of these reachable for explicit free, delete
# the entry so we can catch regressions.

# Keyword / plugin tables built once at startup from static data.
leak:plugin_keywords_add
leak:plugin_keyword_register
leak:keyword_table_init

# Static diagnostic / error-code tables.
leak:diag_explain_register
leak:explain_init

# BearSSL one-time state (trust anchors loaded once from a static array).
leak:bearssl_trust_init
