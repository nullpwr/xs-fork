# LeakSanitizer suppressions for the XS binary.
#
# Only suppress allocations whose lifetime is deliberately process-wide.
# Anything per-request or per-program run must be freed and NOT suppressed;
# those leaks indicate a real bug.
#
# If a future change makes one of these reachable for explicit free, delete
# the entry so we can catch regressions.

# Keyword / plugin tables built once at startup from static data.
leak:plugin_keywords_add
leak:plugin_keyword_register
leak:keyword_table_init

# Static diagnostic / error-code tables.
leak:diag_explain_register
leak:explain_init

# BearSSL one-time state (trust anchors loaded once from a static array).
leak:bearssl_trust_init

# Lexer token string buffers. Identifiers live for the whole program run;
# we don't walk the token list at exit to free each sb, so one-shot xs
# runs hold them until _exit.
leak:sb_push

# Type-checker metadata. Types get stapled onto Symbols and live for the
# life of the SymTab, which itself is process-lifetime in the xs CLI.
leak:ty_fn
leak:tc_walk

# VM bytecode: Proto chunks, opcode buffers, const tables, global-name
# interns, fn prologue strdups. One per compilation unit, released only
# at process exit today.
leak:proto_new
leak:chunk_write
leak:chunk_add_const
leak:compile_fn
leak:emit_global_name

# VM runtime working memory: IC arrays grown lazily in OP_GET_GLOBAL,
# closure/upvalue objects still refcounted > 0 at exit because globals
# pin them.
leak:vm_dispatch
